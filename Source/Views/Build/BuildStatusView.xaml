<UserControl x:Class="FastBuild.Dashboard.Views.Build.BuildStatusView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:support="clr-namespace:FastBuild.Dashboard.Support"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="900">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/MaterialDesignThemes.Wpf;component/Themes/MaterialDesignTheme.Button.xaml" />
                <ResourceDictionary Source="pack://application:,,,/MaterialDesignThemes.Wpf;component/Themes/MaterialDesignTheme.ComboBox.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <Style TargetType="TextBlock"
                   x:Key="SummaryLabel"
                   BasedOn="{StaticResource MaterialDesignCaptionTextBlock}">
                <Setter Property="Opacity" Value="0.72" />
            </Style>

            <Style TargetType="TextBlock"
                   x:Key="SummaryValue"
                   BasedOn="{StaticResource MaterialDesignSubheadingTextBlock}">
                <Setter Property="Margin" Value="0,2,0,0" />
            </Style>

            <Style TargetType="TextBlock"
                   x:Key="LogLevelText"
                   BasedOn="{StaticResource MaterialDesignBody2TextBlock}">
                <Style.Triggers>
                    <DataTrigger Binding="{Binding IsError}" Value="True">
                        <Setter Property="Foreground" Value="{StaticResource JobBackgroundBrush_Failed}" />
                    </DataTrigger>
                    <DataTrigger Binding="{Binding IsWarning}" Value="True">
                        <Setter Property="Foreground" Value="{StaticResource JobBackgroundBrush_Timeout}" />
                    </DataTrigger>
                </Style.Triggers>
            </Style>
        </ResourceDictionary>
    </UserControl.Resources>

    <DockPanel>
        <Border Height="{StaticResource TitleColorZoneHeight}"
                Margin="{StaticResource MainPageTitleMargin}"
                Padding="16"
                DockPanel.Dock="Top">
            <Grid TextElement.Foreground="{DynamicResource PrimaryHueDarkForegroundBrush}"
                  VerticalAlignment="Center">
                <TextBlock Style="{DynamicResource MaterialDesignTitleTextBlock}"
                           VerticalAlignment="Center"
                           Text="Build Status" />
            </Grid>
        </Border>

        <Grid Margin="16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border CornerRadius="2"
                    BorderThickness="1"
                    BorderBrush="{DynamicResource MaterialDesignDivider}"
                    Padding="16">
                <StackPanel>
                    <TextBlock Text="{Binding CurrentSession.StatusText, TargetNullValue='No build session'}"
                               Style="{DynamicResource MaterialDesignSubheadingTextBlock}" />
                    <TextBlock Text="{Binding CurrentSession.BuildProgressText, TargetNullValue='0 of 0 built (0%)'}"
                               Margin="0,4,0,12" />

                    <UniformGrid Columns="8">
                        <StackPanel>
                            <TextBlock Style="{StaticResource SummaryLabel}" Text="Total" />
                            <TextBlock Style="{StaticResource SummaryValue}"
                                       Text="{Binding CurrentSession.TotalJobCount, TargetNullValue=0}" />
                        </StackPanel>
                        <StackPanel>
                            <TextBlock Style="{StaticResource SummaryLabel}" Text="Remaining" />
                            <TextBlock Style="{StaticResource SummaryValue}"
                                       Text="{Binding CurrentSession.RemainingJobCount, TargetNullValue=0}" />
                        </StackPanel>
                        <StackPanel>
                            <TextBlock Style="{StaticResource SummaryLabel}" Text="In Progress" />
                            <TextBlock Style="{StaticResource SummaryValue}"
                                       Text="{Binding CurrentSession.InProgressJobCount, TargetNullValue=0}" />
                        </StackPanel>
                        <StackPanel>
                            <TextBlock Style="{StaticResource SummaryLabel}" Text="Successful" />
                            <TextBlock Style="{StaticResource SummaryValue}"
                                       Text="{Binding CurrentSession.SuccessfulJobCount, TargetNullValue=0}" />
                        </StackPanel>
                        <StackPanel>
                            <TextBlock Style="{StaticResource SummaryLabel}" Text="Preprocessed" />
                            <TextBlock Style="{StaticResource SummaryValue}"
                                       Text="{Binding CurrentSession.PreprocessedJobCount, TargetNullValue=0}" />
                        </StackPanel>
                        <StackPanel>
                            <TextBlock Style="{StaticResource SummaryLabel}" Text="Cache Hit" />
                            <TextBlock Style="{StaticResource SummaryValue}"
                                       Text="{Binding CurrentSession.CacheHitCount, TargetNullValue=0}" />
                        </StackPanel>
                        <StackPanel>
                            <TextBlock Style="{StaticResource SummaryLabel}" Text="Failed" />
                            <TextBlock Style="{StaticResource SummaryValue}"
                                       Text="{Binding CurrentSession.FailedJobCount, TargetNullValue=0}" />
                        </StackPanel>
                        <StackPanel>
                            <TextBlock Style="{StaticResource SummaryLabel}" Text="Warnings" />
                            <TextBlock Style="{StaticResource SummaryValue}"
                                       Text="{Binding CurrentSession.WarningJobCount, TargetNullValue=0}" />
                        </StackPanel>
                    </UniformGrid>
                </StackPanel>
            </Border>

            <DockPanel Grid.Row="1"
                       Margin="0,16,0,8">
                <StackPanel DockPanel.Dock="Right"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <Button Command="{Binding CopySelectedBuildLogCommand}"
                            Style="{StaticResource MaterialDesignFlatButton}"
                            Margin="0,0,8,0"
                            Content="Copy Selected" />
                    <Button Command="{Binding CopyVisibleBuildLogsCommand}"
                            Style="{StaticResource MaterialDesignFlatButton}"
                            Margin="0,0,16,0"
                            Content="Copy Visible" />
                    <TextBlock Text="Filter"
                               VerticalAlignment="Center"
                               Margin="0,0,8,0" />
                    <ComboBox ItemsSource="{Binding LogFilters}"
                              SelectedItem="{Binding SelectedLogFilter}"
                              Width="132" />
                </StackPanel>

                <StackPanel Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <TextBlock Text="{Binding TotalLogCount, StringFormat={}{0} tasks}" />
                    <TextBlock Text="{Binding ErrorLogCount, StringFormat={}  {0} errors}"
                               Margin="16,0,0,0" />
                    <TextBlock Text="{Binding WarningLogCount, StringFormat={}  {0} warnings}"
                               Margin="16,0,0,0" />
                </StackPanel>
            </DockPanel>

            <Grid Grid.Row="2">
                <ListView ItemsSource="{Binding VisibleBuildLogs}"
                          SelectedItem="{Binding SelectedBuildLog}"
                          ScrollViewer.HorizontalScrollBarVisibility="Auto"
                          VirtualizingStackPanel.IsVirtualizing="True"
                          VirtualizingStackPanel.VirtualizationMode="Recycling">
                    <ListView.InputBindings>
                        <KeyBinding Key="C"
                                    Modifiers="Control"
                                    Command="{Binding CopySelectedBuildLogCommand}" />
                    </ListView.InputBindings>
                    <ListView.ContextMenu>
                        <ContextMenu>
                            <MenuItem Header="Copy Selected"
                                      Command="{Binding PlacementTarget.DataContext.CopySelectedBuildLogCommand, RelativeSource={RelativeSource AncestorType={x:Type ContextMenu}}}" />
                            <MenuItem Header="Copy Visible"
                                      Command="{Binding PlacementTarget.DataContext.CopyVisibleBuildLogsCommand, RelativeSource={RelativeSource AncestorType={x:Type ContextMenu}}}" />
                        </ContextMenu>
                    </ListView.ContextMenu>
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Header="Time" Width="72">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding DisplayTime}" />
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>

                            <GridViewColumn Header="Level" Width="92">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal">
                                            <materialDesign:PackIcon Kind="{Binding Icon}"
                                                                     Width="16"
                                                                     Height="16"
                                                                     VerticalAlignment="Center" />
                                            <TextBlock Text="{Binding Level}"
                                                       Style="{StaticResource LogLevelText}"
                                                       Margin="6,0,0,0" />
                                        </StackPanel>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>

                            <GridViewColumn Header="Result" Width="112">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding ResultText}" />
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>

                            <GridViewColumn Header="Host" Width="112">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding HostName}" />
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>

                            <GridViewColumn Header="Task" Width="280">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding DisplayName}"
                                                   TextTrimming="CharacterEllipsis"
                                                   ToolTip="{Binding EventName}" />
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>

                            <GridViewColumn Header="Message" Width="420">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Message}"
                                                   FontFamily="{StaticResource MonoFont}"
                                                   TextTrimming="CharacterEllipsis"
                                                   ToolTip="{Binding Message}" />
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                        </GridView>
                    </ListView.View>
                </ListView>

                <Border Background="{DynamicResource MaterialDesignPaper}"
                        Visibility="{Binding HasVisibleLogs, Converter={support:BoolToVisibilityConverter TrueValue=Collapsed, FalseValue=Visible}}">
                    <TextBlock Text="No task logs"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Opacity="0.64" />
                </Border>
            </Grid>
        </Grid>
    </DockPanel>
</UserControl>
